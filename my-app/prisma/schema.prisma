generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  
}

model User { 
  id    Int     @id @default(autoincrement()) 
  username String  @unique
  password String
  name  String?
  posts Blog[]
} 
model Blog { 
  id        Int     @id @default(autoincrement()) 
  title     String
  content   String
  published Boolean @default(false) 
  author    User    @relation(fields: [authorId], references: [id]) 
  authorId  Int
} 